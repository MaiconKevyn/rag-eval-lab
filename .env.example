# Copy to .env and fill in. Never commit .env.

# OpenAI — used for embeddings, generation, and the LLM-as-a-Judge
OPENAI_API_KEY=sk-...

# Pinecone — vector store. Index must be created with the same dimension
# as the embedding model (text-embedding-3-small = 1536, large = 3072).
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=rag-eval-lab
PINECONE_ENVIRONMENT=us-east-1

# Logging — DEBUG | INFO | WARNING | ERROR (default INFO)
LOG_LEVEL=INFO
